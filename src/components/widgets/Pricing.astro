---
import { Icon } from 'astro-icon/components';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Price } from '~/types';

const { title, subtitle, tagline, prices = [], classes = {}, ...rest } = Astro.props;
---

<WidgetWrapper {...rest} id="pricing" classes={{ container: 'max-w-7xl scroll-mt-16', ...classes.container }} hasBackground>
  <Headline {title} {subtitle} {tagline} classes={{ headline: 'max-w-3xl' }}>
    <slot name="title" slot="title" />
    <slot name="subtitle" slot="subtitle" />
  </Headline>
  
  <div class:list={['gap-8', { 'flex justify-center': prices.length === 1, 'grid sm:grid-cols-2 lg:grid-cols-3': prices.length > 1 }, classes?.grid]}>
    {prices.map((price) => (
        <div class:list={['relative overflow-visible flex flex-col rounded-lg border-2 p-8 text-center shadow-lg bg-white dark:bg-slate-900', { 'border-primary': price.hasRibbon, 'border-gray-200 dark:border-slate-800': !price.hasRibbon, 'w-full max-w-lg': prices.length === 1 }]}>
          <h3 class="text-2xl font-bold">{price.title}</h3>
          {price.subtitle && <p class="mt-4 text-muted">{price.subtitle}</p>}
          
          <div class="mt-8">
            <div class="flex items-end justify-center">
              <span class="text-5xl font-bold tracking-tight">${price.price}</span>
              <span class="ml-1 text-xl font-medium text-muted">/{price.period}</span>
            </div>
            
            <ul role="list" class="mt-8 space-y-4 text-left border-b border-gray-100 dark:border-slate-800 pb-8">
              {price.items.map((item) => (
                <li class="flex items-start">
                  <Icon name="tabler:circle-check" class="w-6 h-6 text-primary flex-shrink-0" />
                  <p class="ml-3 text-base text-muted">{item.description}</p>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Interactive Selection Form -->
          <div class="mt-8 text-left space-y-6">
            <form action="https://www.paypal.com/cgi-bin/webscr" method="post" target="_top" id="secure-url-form">
                <input type="hidden" name="cmd" value="_xclick" />
                <input type="hidden" name="business" value="ZFG89TK2KESFG" />
                <input type="hidden" name="item_name" value="Launch.Skin Clinical Homepage License" />
                <input type="hidden" name="item_number" value="LS-LTD-99" />
                <input type="hidden" name="amount" value="99.00" />
                <input type="hidden" name="currency_code" value="USD" />
                <input type="hidden" name="no_shipping" value="1" />

                <!-- Field 1: Vanity URL -->
                <div class="space-y-2">
                    <label class="block text-sm font-bold text-gray-700 dark:text-gray-300">1. Choose Your Vanity URL</label>
                    <input 
                      type="text" 
                      id="vanity-input"
                      name="os0" 
                      required 
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition" 
                      placeholder="yourclinic" 
                    />
                    <input type="hidden" name="on0" value="Vanity URL Request" />
                    
                    <!-- URL Preview Box -->
                    <div class="mt-3 p-4 bg-blue-50 dark:bg-blue-900/30 border border-blue-100 dark:border-blue-800 rounded-lg flex items-center gap-3">
                        <Icon name="tabler:world" class="w-5 h-5 text-primary" />
                        <span class="text-sm font-medium text-gray-600 dark:text-gray-300 break-all">
                            https://launch.skin/<span id="url-preview" class="text-primary font-bold underline">yourclinic</span>
                        </span>
                    </div>
                </div>

                <!-- Field 2: Clinic Name -->
                <div class="space-y-2 mt-6">
                    <label class="block text-sm font-bold text-gray-700 dark:text-gray-300">2. Clinic Name</label>
                    <input 
                      type="text" 
                      name="os1" 
                      required 
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition" 
                      placeholder="Business Name" 
                    />
                    <input type="hidden" name="on1" value="Clinic Business Name" />
                </div>

                <button type="submit" class="w-full mt-8 py-4 px-6 bg-primary hover:bg-blue-700 text-white font-bold text-lg rounded-xl shadow-xl hover:shadow-primary/20 transform hover:-translate-y-1 transition duration-200 flex items-center justify-center gap-2">
                  Secure My URL Today <Icon name="tabler:chevron-right" class="w-5 h-5" />
                </button>
                
                <div class="mt-4 flex items-center justify-center gap-2 opacity-50">
                    <Icon name="tabler:lock" class="w-3 h-3" />
                    <p class="text-[10px] uppercase tracking-widest font-bold">Secure Global Checkout</p>
                </div>
            </form>
          </div>
        </div>
    ))}
  </div>

  <script is:inline>
    function initPricingForm() {
      const input = document.getElementById('vanity-input');
      const preview = document.getElementById('url-preview');
      
      if (input && preview) {
        input.addEventListener('input', (e) => {
          // Clean the input: lowercase, replace spaces/special chars with hyphens
          let val = e.target.value.toLowerCase().replace(/[^a-z0-9]/g, '-').replace(/-+/g, '-');
          if (val.startsWith('-')) val = val.substring(1);
          
          input.value = val;
          preview.textContent = val || 'yourclinic';
        });
      }
    }

    // Run on initial load
    initPricingForm();
    // Run on view transitions navigation
    document.addEventListener('astro:after-swap', initPricingForm);
  </script>
</WidgetWrapper>
