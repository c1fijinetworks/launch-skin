---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Hero from '~/components/widgets/Hero.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = { title: 'Pricing | Launch.Skin' };
---
<Layout metadata={metadata}>
  <HeroText tagline="The Professional Standard" title="A Stunning Home for Your Practice." subtitle="Transform your social bio into a high-end experience with a professional vanity URL." />

  <Pricing prices={[lifetimeDeal]} />

  <Features3
    title="Elevate Every Touchpoint"
    columns={3}
    items={[
      { title: 'Social Bio Transformation', description: 'Ditch generic link tools for a high-end experience.', icon: 'tabler:link' },
      { title: 'Google Business Authority', description: 'Replace generic links with a dedicated clinical homepage.', icon: 'tabler:brand-google' },
      { title: 'Live Results Sync', description: 'Automated Instagram portfolio updates 24/7.', icon: 'tabler:brand-instagram' },
      { title: 'Detailed Treatment Menu', description: 'Present your services with boutique medical-grade styling.', icon: 'tabler:clipboard-list' },
      { title: 'One-Time License', description: 'Pay once and own your professional identity for life.', icon: 'tabler:coin' },
      { title: 'White-Glove Delivery', description: 'Guaranteed same-day technical setup.', icon: 'tabler:headset' },
    ]}
  />

  <FAQs
    title="Pricing Questions"
    items={[
        { title: 'How does same-day setup work?', description: 'Order by 2PM EST and your site goes live before the business day ends.' },
        { title: 'Can I use a custom .com?', description: 'Yes! We can manage your standalone domain for $15/year.' },
    ]}
  />

  <Hero class="-mt-16"><Fragment slot="image"><img src="/images/testimonial-5.webp" alt="Results" class="mx-auto rounded-md w-full shadow-lg" /></Fragment></Hero>

  <CallToAction title="Ready to Launch?" subtitle="Claim your URL today." actions={[{ variant: 'primary', text: 'Secure My $99 Deal', href: '#pricing' }]} />
</Layout>
