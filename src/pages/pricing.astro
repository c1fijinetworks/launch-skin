---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Hero from '~/components/widgets/Hero.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = { title: 'Pricing | Launch.Skin' };
---
<Layout metadata={metadata}>
  <HeroText 
    tagline="The Professional Standard" 
    title="A Stunning Home for Your Practice." 
    subtitle="Transform your social bio into a high-end experience with a dedicated vanity URL." 
    actions={[
      { variant: 'primary', text: 'Secure My $99 Deal', href: '#pricing' },
      { text: 'Experience the Demo Clinic', href: '/demo' }
    ]}
  />

  <Pricing prices={[lifetimeDeal]} />

  <Features3
    title="Elevate Every Touchpoint"
    columns={3}
    items={[
      { title: 'Social Bio Transformation', description: 'Ditch generic link tools for a high-end, branded experience.', icon: 'tabler:link' },
      { title: 'Google Business Authority', description: 'Replace generic links with a dedicated clinical homepage.', icon: 'tabler:brand-google' },
      { title: 'Mobile-First Design', description: 'Your site looks flawless on every device your clients use.', icon: 'tabler:device-mobile' },
      { title: 'Professional Domain', description: 'Exclusive launch.skin vanity URL included with every license.', icon: 'tabler:id' },
      { title: 'One-Time License', description: 'Pay once and own your professional identity for life.', icon: 'tabler:coin' },
      { title: 'White-Glove Delivery', description: 'Guaranteed same-day technical setup by our team.', icon: 'tabler:headset' },
    ]}
  />

  <FAQs
    title="Pricing Questions"
    items={[
        { title: 'How does same-day setup work?', description: 'Order by 2PM EST and your professional clinical homepage goes live before the business day ends.' },
        { title: 'Can I use a custom .com?', description: 'Yes! While we specialize in .skin vanity URLs, we can connect your site to any standalone domain you own.' },
        { title: 'Are there any hidden renewal fees?', description: 'None. Your $99 payment covers the license, setup, and ongoing technical hosting for the lifetime of the product. No monthly subscriptions, ever.' },
        { title: 'What content do I need to provide?', description: 'Just your clinic name, contact details, and a few high-quality images. Our boutique studio handles the layout, design, and technical configuration for you.' },
    ]}
  />

  <Hero class="-mt-16"><Fragment slot="image"><img src="/images/testimonial-5.webp" alt="Results" class="mx-auto rounded-md w-full shadow-lg" /></Fragment></Hero>

  <CallToAction 
    title="Ready to Launch?" 
    subtitle="Claim your professional address today or see a finished example." 
    actions={[
      { variant: 'primary', text: 'Secure My $99 Deal', href: '#pricing' },
      { text: 'Tour Your Future Website', href: '/demo' }
    ]} 
  />
</Layout>
