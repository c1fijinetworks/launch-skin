---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import GoogleContactForm from '~/components/widgets/GoogleContactForm.astro';

const metadata = {
  title: 'Contact | Launch.Skin',
  description: 'Reach out for white-glove setup or support for your clinic website.',
};
---
<Layout metadata={metadata}>
  <HeroText 
    tagline="Support"
    title="We handle everything." 
    subtitle="Have questions about the Launch.Skin boutique concept? Our team is ready to help your practice shine online."
  />
  <GoogleContactForm />
</Layout>
