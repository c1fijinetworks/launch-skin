---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import GoogleContactForm from '~/components/widgets/GoogleContactForm.astro';

const metadata = {
  title: 'Support | Launch.Skin',
  description: 'Reach out for white-glove setup or support for your clinical vanity URL.',
};
---
<Layout metadata={metadata}>
  <HeroText 
    tagline="Support"
    title="White-Glove Setup." 
    subtitle="Have questions about securing your clinical vanity URL? Our team is ready to help your practice shine online."
  />
  <GoogleContactForm />
</Layout>
