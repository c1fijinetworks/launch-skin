---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = { 
  title: 'Launch.Skin | Digital Masterpieces for Elite Skin Clinics', 
  description: 'The $99 luxury alternative to monthly website subscriptions. Automated Instagram portfolios for the world’s best skin practitioners.' 
};
---
<Layout metadata={metadata}>
  <Hero2
    tagline="The New Standard for Clinic Web Design"
    title='Your Practice Deserves a <span class="italic text-accent">Digital Masterpiece.</span>'
    subtitle="We build high-end websites that sync with your social portfolio in real-time. No subscriptions. No tech stress. Just luxury for your brand."
    actions={[
      { variant: 'primary', text: "Secure Your URL - $99", href: '/pricing' }, 
      { text: 'View Live Demo', href: '/demo' }
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?auto=format&fit=crop&q=80&w=1024', width: 1024, height: 576 }}
  />

  <Features
    id="features"
    title="Elite Features for Elite Practitioners"
    items={[
        { title: 'Insta-Sync™ Technology', description: 'Your website updates automatically every time you post a treatment result to Instagram. Zero manual maintenance.', icon: 'tabler:brand-instagram' },
        { title: 'Google Authority Signal', description: 'Replace generic bio links with a professional website that signals elite status to Google search users.', icon: 'tabler:brand-google' },
        { title: 'Vanity .Skin Address', description: 'Ditch messy booking links for a professional launch.skin/yourclinic vanity URL.', icon: 'tabler:world' },
        { title: 'One-Time Investment', description: 'Stop the monthly subscription drain. Pay $99 once and own your digital flagship for life.', icon: 'tabler:coin' },
    ]}
  />

  <Content
    title="Always Fresh. Never Maintenance."
    subtitle="Your portfolio shouldn't be a chore. We connect your Instagram so your site reflects your clinical results 24/7."
    image={{ src: 'https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=800', alt: 'Live Feed Results' }}
  />

  <Pricing prices={[lifetimeDeal]} />

  <FAQs
    title="Common Questions"
    items={[
        { title: 'Is it really $99 forever?', description: 'Yes. We don’t believe in "SaaS taxes" for practitioners. You pay for the setup and lifetime hosting license once.' },
        { title: 'How long does setup take?', description: 'If you secure your URL by 2 PM, we usually have your custom sync and clinical dashboard live by the time you close your clinic.' },
    ]}
  />
</Layout>
