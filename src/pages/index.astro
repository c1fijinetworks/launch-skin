---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import { headerData } from '~/navigation';
import FAQs from '~/components/widgets/FAQs.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = {
  title: 'Launch.Skin | Premium Vanity URLs for Elite Skin Clinics',
  description: 'High-end clinical websites with dedicated vanity URLs for elite practitioners. Replace messy bio links with a professional flagship address. $99 Forever.',
};
---

<Layout metadata={metadata}>
  <Fragment slot="header"><Header {...headerData} isSticky /></Fragment>
  
  <Hero2
    tagline="Boutique Web Development for Practitioners"
    title='<span class="text-accent dark:text-white">Your Practice Deserves a Professional Address.</span>'
    subtitle="We build high-end clinical homepages that establish instant authority. Replace generic bio links with a professional launch.skin vanity URL while you focus on your clients."
    actions={[
      { variant: 'primary', text: "Claim Your Clinic's Address", href: '/pricing/' }, 
      { text: 'Explore the Aesthetic Showroom', href: '/demo' }
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?auto=format&fit=crop&q=80&w=1024', width: 1024, height: 576 }}
  />
  
  <Features
    id="features"
    title="Elite Identity for Elite Clinics"
    subtitle="Essential elements of a high-performance clinical presence in a single, beautiful package."
    items={[
        { title: 'Branded Vanity URL', description: 'Secure your name at launch.skin/yourclinic. A professional address that is easy for clients to remember and type.', icon: 'tabler:link' },
        { title: 'Aesthetic Medical Design', description: 'Custom-crafted layouts that mirror the luxury and cleanliness of your physical clinic space.', icon: 'tabler:palette' },
        { title: 'Search Authority Signal', description: 'Replace generic social links with a professional site that signals elite status to Google Search and local Maps.', icon: 'tabler:brand-google' },
        { title: 'One-Time Investment', description: 'Stop paying $150/month for complex website builders. Pay $99 once and own your clinical flagship for life.', icon: 'tabler:coin' },
    ]}
  />

  <Content
    tagline="Always Professional. Always On."
    title="The Premier Digital Front Door."
    items={[
        { title: 'Simplified Bio Presence', description: 'Streamline your social media presence with one professional link.', icon: 'tabler:check' },
        { title: 'Authority SEO Signal', description: 'Google prioritizes professional dedicated URLs over generic social links.', icon: 'tabler:trending-up' },
        { title: 'Booking Integration', description: 'Connect your existing booking platform directly to your boutique homepage.', icon: 'tabler:calendar-event' },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=800', alt: 'Elite Clinical Homepage' }}
    callToAction={{ text: 'Step Into the Masterpiece Demo', href: '/demo', variant: 'link' }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Build Instant Trust</h3>
      <p>In the aesthetic industry, presentation is everything. Our boutique websites ensure your digital handshake is as polished as your clinical results.</p>
    </Fragment>
    <Fragment slot="bg"><div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div></Fragment>
  </Content>

  <Steps2
    title="Three Simple Steps to Launch"
    subtitle="The path to a professional clinical presence begins here."
    items={[
      { title: '01. Secure Your Brand', description: 'Choose your preferred vanity URL and secure your lifetime license.', icon: 'tabler:number-1' },
      { title: '02. We Build Your Site', description: 'Our studio crafts your clinical homepage with high-end, medical-grade styling.', icon: 'tabler:number-2' },
      { title: '03. Go Live', description: 'Launch on launch.skin/yourclinic and start attracting high-value clients immediately.', icon: 'tabler:number-3' },
    ]}
    image={{ src: '/images/testimonial-6.webp', alt: 'Launch.Skin Process' }}
    callToAction={{ text: 'See a Finished Clinic Site', href: '/demo' }}
  />

  <Pricing title='One-Time Investment. Lifetime Identity.' prices={[lifetimeDeal]} />

  <FAQs
    title="Common Questions"
    items={[
        { title: 'What is a Vanity URL?', description: 'A branded, professional link like <strong>launch.skin/yourclinic</strong>. It replaces messy, generic links in your bio with a dedicated clinical presence.' },
        { title: 'Is it really $99 forever?', description: 'Yes. We charge for setup and technical hosting once. You never pay a monthly subscription fee or recurring maintenance bill again.' },
        { title: 'Can I change my link later?', description: 'Your vanity URL is secured at the time of setup. If you rebrand, our support team can assist with migrating to a new professional address.' },
        { title: 'How does this help my SEO?', description: 'Search engines like Google prioritize professional, dedicated URLs over generic social profile links. A <strong>launch.skin</strong> address signals specialized authority in the aesthetics industry, helping you rank higher in local search results.' },
    ]}
  />
</Layout>
