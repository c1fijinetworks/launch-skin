---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import Hero from '~/components/widgets/Hero.astro';
import { lifetimeDeal } from '~/data/pricingData';

const metadata = { title: 'Our Story | Launch.Skin' };
---
<Layout metadata={metadata}>
  <Hero2
    tagline="Our Philosophy"
    title='The Digital Address for <span class="text-accent">Elite Practitioners</span>'
    subtitle="We believe your digital address should be as beautiful as the results you create. Your website is your digital handshake; it should reflect clinical luxury."
    actions={[
      { variant: 'primary', text: 'Secure My Address', href: '/pricing/' },
      { text: 'Tour the Digital Masterpiece', href: '/demo' }
    ]}
    image={{ src: '/images/hero-poster.webp', alt: 'Launch.Skin Branding' }}
  />
  
  <Content
    isReversed={false}
    items={[
        { title: 'Mirror Your Luxury', description: 'Your digital home should signal expertise before a client even walks through your door.', icon: 'tabler:award' },
        { title: 'Focus on Results, Not Tech', description: 'We handle the servers and code so you can focus on making your clients feel their best.', icon: 'tabler:brush' },
        { title: 'Google Search Authority', description: 'A dedicated launch.skin address serves as a powerful SEO signal to Google, helping you dominate local search rankings.', icon: 'tabler:brand-google' },
        { title: 'Zero-Maintenance Lifestyle', description: 'Forget plugin updates and broken layouts. Our enterprise-grade stack stays live and secure 24/7 with no input from you.', icon: 'tabler:tool' },
    ]}
    callToAction={{ text: 'See the Clinical Standard', href: '/demo', variant: 'link' }}
  >
    <Fragment slot="content">
      <h3 class="text-3xl font-bold mb-4">Our Technical Philosophy</h3>
      <p class="text-lg text-muted">In the modern aesthetics industry, a generic "Link-in-Bio" is a missed opportunity. We provide a dedicated digital address that establishes local authority and builds trust.</p>
    </Fragment>
    <Fragment slot="image"><img src="/images/testimonial-4.webp" alt="Elite Clinic" class="rounded-lg shadow-xl w-full" /></Fragment>
  </Content>

  <Content
    isReversed={true}
    items={[
        { title: 'A New Clinical Standard', description: 'Establish your brand on a domain dedicated exclusively to the world of skin and aesthetic artistry.', icon: 'tabler:rocket' },
        { title: 'White-Glove Support', description: 'We configure your vanity URL and launch your site so you can stay focused in the treatment room.', icon: 'tabler:headset' },
        { title: 'Bio-Link Optimization', description: 'Replace cluttered, generic link-trees with a focused, high-converting digital storefront that drives direct bookings.', icon: 'tabler:device-mobile' },
        { title: 'Global Edge Performance', description: 'Your site is deployed on a global edge network, ensuring instant loading speeds for every potential client, everywhere.', icon: 'tabler:bolt' },
    ]}
    callToAction={{ text: 'View the Aesthetic Showroom', href: '/demo', variant: 'link' }}
  >
    <Fragment slot="content"><h3 class="text-3xl font-bold mb-4">The Digital Difference</h3></Fragment>
    <Fragment slot="image"><img src="/images/testimonial-3.webp" alt="Practitioner" class="rounded-lg shadow-xl w-full" /></Fragment>
  </Content>

  <Pricing title="Own Your Professional Identity" prices={[lifetimeDeal]} />
  <Hero class="-mt-16"><Fragment slot="image"><img src="/images/testimonial-6.webp" alt="Preview" class="mx-auto rounded-md w-full shadow-lg" /></Fragment></Hero>
</Layout>
