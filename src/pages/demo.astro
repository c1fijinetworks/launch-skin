---
// Standalone Demo Page for Launch.Skin
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lumière Skin Clinic - Luxury Aesthetics Demo | Launch.Skin</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <script is:inline src="https://unpkg.com/@tailwindcss/browser@4"></script>
  <script is:inline src="https://unpkg.com/lucide@latest"></script>

  <style type="text/tailwindcss" is:inline>
    @theme {
      --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
      --font-serif: "Playfair Display", serif;
      --color-primary: #1a1a1a;
      --color-accent: #C5A059;
      --color-bg: #FAF9F6;
    }
    @layer base {
      body { @apply bg-bg text-primary font-sans antialiased selection:bg-accent/30; }
      h1, h2, h3, h4, h5, h6 { @apply font-serif; }
    }
  </style>

  <style is:inline>
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade-up-1 { animation: fadeInUp 0.8s ease-out 0.2s both; }
    .animate-fade-up-2 { animation: fadeInUp 0.8s ease-out 0.4s both; }
    .animate-fade-up-3 { animation: fadeInUp 0.8s ease-out 0.8s both; }
    @keyframes slideInUp { from { opacity: 0; transform: translateY(100px); } to { opacity: 1; transform: translateY(0); } }
    .animate-slide-up { animation: slideInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 2s both; }
    #mobile-menu { transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease; transform: translateX(100%); opacity: 0; pointer-events: none; }
    #mobile-menu.open { transform: translateX(0); opacity: 1; pointer-events: auto; }
  </style>
</head>
<body>

  <!-- Navigation -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent py-8 text-bg">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span class="text-2xl font-serif tracking-widest uppercase font-medium">Lumière</span>
        <span class="text-[10px] tracking-[0.3em] uppercase opacity-60 mt-1">Skin Clinic</span>
      </div>
      <div class="hidden md:flex items-center gap-12 text-xs uppercase tracking-[0.2em] font-medium">
        <a href="#about" class="hover:text-accent transition-colors">About</a>
        <a href="#services" class="hover:text-accent transition-colors">Treatments</a>
        <a href="#gallery" class="hover:text-accent transition-colors">Results</a>
        <a href="#reviews" class="hover:text-accent transition-colors">Reviews</a>
        <button id="nav-btn" class="bg-bg text-primary px-8 py-3 hover:bg-accent hover:text-bg transition-all duration-300">Book Appointment</button>
      </div>
      <button id="menu-btn" class="md:hidden cursor-pointer text-inherit"><i data-lucide="menu" class="w-6 h-6"></i></button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 z-[60] bg-bg text-primary flex flex-col p-8">
    <div class="flex justify-end"><button id="close-menu-btn"><i data-lucide="x" class="w-8 h-8"></i></button></div>
    <div class="flex flex-col gap-8 mt-12 text-2xl font-serif">
      <a href="#about" class="mobile-link">About</a><a href="#services" class="mobile-link">Treatments</a><a href="#gallery" class="mobile-link">Results</a><a href="#reviews" class="mobile-link">Reviews</a>
      <button class="bg-primary text-bg py-4 mt-4">Book Now</button>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?auto=format&fit=crop&q=80&w=1920" alt="Luxury Clinic Interior" class="w-full h-full object-cover scale-105 transition-transform duration-[20s] ease-linear hover:scale-110"/>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    <div class="relative z-10 text-center text-bg px-6 max-w-4xl">
      <span class="animate-fade-up-1 text-xs uppercase tracking-[0.5em] mb-6 block font-medium">Science-Backed Aesthetics</span>
      <h1 class="animate-fade-up-2 text-5xl md:text-8xl font-serif mb-8 leading-[1.1]">Your Skin <br /> <span class="italic">Reimagined.</span></h1>
      <div class="animate-fade-up-3 flex flex-col md:flex-row items-center justify-center gap-6">
        <button class="bg-accent text-bg px-10 py-4 text-xs uppercase tracking-widest hover:bg-bg hover:text-primary transition-all duration-500 w-full md:w-auto">View Treatments</button>
        <button class="border border-bg/30 backdrop-blur-sm text-bg px-10 py-4 text-xs uppercase tracking-widest hover:bg-bg/10 transition-all duration-500 w-full md:w-auto">The Experience</button>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-24 md:py-40 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden"><img src="https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=800" alt="Clinical treatment" class="w-full h-full object-cover"/></div>
        <div class="absolute -bottom-8 -right-8 w-64 h-80 hidden md:block border-8 border-bg z-10"><img src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&q=80&w=400" alt="Skin Detail" class="w-full h-full object-cover"/></div>
      </div>
      <div class="space-y-8">
        <span class="text-accent text-xs uppercase tracking-[0.3em] font-semibold">Bespoke Clinical Care</span>
        <h2 class="text-4xl md:text-6xl font-serif leading-tight">Precision <br />Meets Radiance.</h2>
        <p class="text-primary/70 leading-relaxed text-lg max-w-xl">At Lumière Skin Clinic, we combine medical-grade technology with a boutique spa experience. Our practitioners specialize in custom-tailored protocols that deliver visible, lasting results.</p>
        <div class="pt-4">
          <a href="#" class="inline-flex items-center gap-4 group text-xs uppercase tracking-widest font-bold">Our Philosophy <div class="w-12 h-[1px] bg-primary group-hover:w-20 transition-all duration-500"></div></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="bg-primary text-bg py-24 md:py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
        <div class="space-y-4">
          <div class="flex items-center gap-3"><div class="flex items-center gap-2 bg-accent/20 text-accent px-3 py-1 rounded-full text-[10px] uppercase tracking-widest font-bold border border-accent/30"><span class="w-1.5 h-1.5 bg-accent rounded-full animate-pulse"></span>Syncing Results</div><span class="text-xs uppercase tracking-widest opacity-60">Insta-Sync™ Technology</span></div>
          <h2 class="text-4xl md:text-6xl font-serif">Clinical Results.</h2>
        </div>
        <div class="flex items-center gap-4 text-xs uppercase tracking-widest opacity-80 hover:opacity-100 cursor-pointer"><i data-lucide="instagram" class="w-5 h-5"></i>Follow @lumiere.skin</div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-8">
        <div class="group relative aspect-square overflow-hidden cursor-pointer"><img src="https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?auto=format&fit=crop&q=80&w=600" class="w-full h-full object-cover transition-all group-hover:scale-110"/><div class="absolute inset-0 bg-black/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"><i data-lucide="instagram" class="text-bg w-8 h-8"></i></div></div>
        <div class="group relative aspect-square overflow-hidden cursor-pointer"><img src="https://images.unsplash.com/photo-1552046122-03184de85e08?auto=format&fit=crop&q=80&w=600" class="w-full h-full object-cover transition-all group-hover:scale-110"/><div class="absolute inset-0 bg-black/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"><i data-lucide="instagram" class="text-bg w-8 h-8"></i></div></div>
        <div class="group relative aspect-square overflow-hidden cursor-pointer"><img src="https://images.unsplash.com/photo-1498843053639-170ff2122f35?auto=format&fit=crop&q=80&w=600" class="w-full h-full object-cover transition-all group-hover:scale-110"/><div class="absolute inset-0 bg-black/20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"><i data-lucide="instagram" class="text-bg w-8 h-8"></i></div></div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-24 md:py-32 px-6">
    <div class="max-w-7xl mx-auto text-center">
      <h2 class="text-4xl md:text-6xl font-serif mb-20">Master Practitioners</h2>
      <div class="grid md:grid-cols-3 gap-12 text-left">
        <div class="group cursor-pointer">
          <div class="aspect-[4/5] overflow-hidden mb-6 relative"><img src="https://images.unsplash.com/photo-1559839734-2b71f1e3c77d?auto=format&fit=crop&q=80&w=500" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" /></div>
          <h3 class="text-2xl font-serif">Dr. Julian Vance</h3>
          <p class="text-accent text-xs uppercase tracking-widest font-medium">Clinical Director</p>
        </div>
        <div class="group cursor-pointer">
          <div class="aspect-[4/5] overflow-hidden mb-6 relative"><img src="https://images.unsplash.com/photo-1594824476967-48c8b964273f?auto=format&fit=crop&q=80&w=500" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" /></div>
          <h3 class="text-2xl font-serif">Amara Saint</h3>
          <p class="text-accent text-xs uppercase tracking-widest font-medium">Lead Esthetician</p>
        </div>
        <div class="group cursor-pointer">
          <div class="aspect-[4/5] overflow-hidden mb-6 relative"><img src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&q=80&w=500" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" /></div>
          <h3 class="text-2xl font-serif">Leo D'Amico</h3>
          <p class="text-accent text-xs uppercase tracking-widest font-medium">Dermal Therapist</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Review Engine -->
  <section id="reviews" class="bg-bg py-24 md:py-32 border-y border-primary/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center mb-16 gap-6">
        <div class="flex items-center gap-4">
          <div class="bg-white p-3 shadow-sm border border-primary/5"><img src="https://upload.wikimedia.org/wikipedia/commons/2/2f/Google_2015_logo.svg" alt="Google" class="h-6" /></div>
          <div><div class="flex items-center gap-1 mb-1"><i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i><i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i><i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i><i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i><i data-lucide="star" class="w-3 h-3 fill-accent text-accent"></i></div><div class="flex items-center gap-2"><span class="text-[10px] font-bold uppercase tracking-widest">Verified Google Reviews</span><i data-lucide="check-circle-2" class="w-3 h-3 text-blue-500"></i></div></div>
        </div>
        <div class="text-center md:text-right"><span class="text-4xl font-serif">4.9</span><span class="text-xs uppercase tracking-widest opacity-60 ml-2">Clinic Average</span></div>
      </div>
      <div class="flex gap-6 overflow-x-auto hide-scrollbar pb-8 snap-x">
        <div class="min-w-[300px] md:min-w-[400px] bg-white p-10 border border-primary/5 snap-start shadow-sm"><p class="text-primary/80 italic mb-8">"The only clinic I trust with my face. The results after three facials have been life-changing."</p><span class="text-xs uppercase tracking-widest font-bold">— Elena Rodriguez</span></div>
        <div class="min-w-[300px] md:min-w-[400px] bg-white p-10 border border-primary/5 snap-start shadow-sm"><p class="text-primary/80 italic mb-8">"Minimalist, clean, and extremely professional. My skin has never looked better."</p><span class="text-xs uppercase tracking-widest font-bold">— James Wilson</span></div>
      </div>
    </div>
  </section>

  <!-- Service Menu -->
  <section id="services" class="py-24 md:py-40 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-center text-4xl md:text-6xl font-serif mb-20">Boutique Treatments</h2>
      <div class="space-y-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-primary/10 pb-8 hover:border-accent transition-colors duration-500"><div class="space-y-2"><h3 class="text-2xl font-serif">Signature Glow Facial</h3><p class="text-primary/60 text-sm">Custom double-cleanse, exfoliation, and oxygen infusion.</p></div><span class="text-accent font-serif text-xl">$180</span></div>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-primary/10 pb-8 hover:border-accent transition-colors duration-500"><div class="space-y-2"><h3 class="text-2xl font-serif">Medical-Grade Peel</h3><p class="text-primary/60 text-sm">Advanced resurfacing for hyperpigmentation and texture.</p></div><span class="text-accent font-serif text-xl">$250</span></div>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-primary/10 pb-8 hover:border-accent transition-colors duration-500"><div class="space-y-2"><h3 class="text-2xl font-serif">Microneedling</h3><p class="text-primary/60 text-sm">Collagen induction therapy for scarring and anti-aging.</p></div><span class="text-accent font-serif text-xl">$450</span></div>
      </div>
      <div class="mt-20 text-center"><button class="bg-primary text-bg px-12 py-5 text-xs uppercase tracking-widest hover:bg-accent transition-all duration-500">View Full Menu</button></div>
    </div>
  </section>

  <!-- Conversion Section -->
  <section class="bg-accent text-bg py-24 px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 opacity-10 translate-x-1/4 -translate-y-1/4 pointer-events-none text-[20rem] font-serif italic">L</div>
    <div class="max-w-7xl mx-auto relative z-10 grid md:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <h2 class="text-4xl md:text-6xl font-serif leading-tight">Get This Website <br />For Your Clinic.</h2>
        <p class="text-bg/80 text-lg leading-relaxed max-w-lg">Launch.Skin gives you this exact luxury platform with result-sync and reputation technology included.</p>
        <a href="/pricing" class="inline-block bg-primary text-bg px-12 py-5 text-xs uppercase tracking-widest hover:bg-bg hover:text-primary transition-all">Claim Your Address</a>
      </div>
      <img src="https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=800" class="rounded-lg shadow-2xl rotate-3" />
    </div>
  </section>

  <footer class="bg-primary text-bg py-20 px-6 text-center">
    <p class="text-[10px] uppercase tracking-widest opacity-40">© 2026 Lumière Skin Clinic — Powered by Launch.Skin</p>
  </footer>

  <!-- Sticky Conversion Footer -->
  <div class="fixed bottom-6 left-6 right-6 md:left-auto md:right-12 md:max-w-sm z-50 animate-slide-up">
    <div class="bg-white text-primary p-6 shadow-2xl border border-accent/20 relative group">
      <div class="absolute top-0 left-0 w-1 h-full bg-accent"></div>
      <div class="flex items-center gap-2 mb-4"><div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div><span class="text-[10px] uppercase font-bold text-accent">Clinic Demo Active</span></div>
      <h5 class="text-lg font-serif mb-2">Love this layout?</h5>
      <p class="text-xs text-primary/60 mb-6">Launch your clinical presence with this template and your own .skin vanity URL for just $99.</p>
      <a href="/pricing" class="w-full inline-flex bg-accent text-bg py-3 text-[10px] uppercase tracking-widest font-bold items-center justify-center gap-2">Get Started Now <i data-lucide="external-link" class="w-3 h-3"></i></a>
    </div>
  </div>

  <script is:inline>
    lucide.createIcons();
    const navbar = document.getElementById('navbar');
    const navBtn = document.getElementById('nav-btn');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.classList.replace('bg-transparent', 'bg-bg/95');
        navbar.classList.replace('py-8', 'py-4');
        navbar.classList.replace('text-bg', 'text-primary');
        navBtn.classList.replace('bg-bg', 'bg-primary');
        navBtn.classList.replace('text-primary', 'text-bg');
      } else {
        navbar.classList.replace('bg-bg/95', 'bg-transparent');
        navbar.classList.replace('py-4', 'py-8');
        navbar.classList.replace('text-primary', 'text-bg');
        navBtn.classList.replace('bg-primary', 'bg-bg');
        navBtn.classList.replace('text-bg', 'text-primary');
      }
    });
    const toggleMenu = () => document.getElementById('mobile-menu').classList.toggle('open');
    document.getElementById('menu-btn').addEventListener('click', toggleMenu);
    document.getElementById('close-menu-btn').addEventListener('click', toggleMenu);
  </script>
</body>
</html>
