---
// Standalone Demo Page for Launch.Skin
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lumière Skin Clinic - Luxury Aesthetics Demo | Launch.Skin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <script is:inline src="https://unpkg.com/@tailwindcss/browser@4"></script>
  <script is:inline src="https://unpkg.com/lucide@latest"></script>
  <style type="text/tailwindcss" is:inline>
    @theme { --font-sans: "Inter"; --font-serif: "Playfair Display"; --color-accent: #C5A059; --color-bg: #FAF9F6; }
    @layer base { body { @apply bg-bg text-[#1a1a1a] font-sans antialiased; } h1, h2, h3 { @apply font-serif; } }
  </style>
  <style is:inline>
    #navbar.scrolled { @apply bg-bg/95 backdrop-blur-md shadow-sm text-primary py-4; }
    #nav-btn.scrolled { @apply bg-primary text-bg; }
  </style>
</head>
<body>
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent py-8 text-bg">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
      <div class="flex items-center gap-2"><span class="text-2xl font-serif tracking-widest uppercase">Lumière</span><span class="text-[10px] tracking-widest opacity-60 mt-1 uppercase">Skin Clinic</span></div>
      <div class="hidden md:flex items-center gap-12 text-xs uppercase tracking-widest font-medium"><a href="#about">About</a><a href="#services">Treatments</a><a href="#gallery">Results</a><button id="nav-btn" class="bg-bg text-primary px-8 py-3 hover:bg-accent hover:text-bg transition-all duration-300">Book Appointment</button></div>
    </div>
  </nav>

  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0"><img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?auto=format&fit=crop&q=80&w=1920" class="w-full h-full object-cover scale-105"/><div class="absolute inset-0 bg-black/40"></div></div>
    <div class="relative z-10 text-center text-bg px-6 max-w-4xl"><h1 class="text-5xl md:text-8xl font-serif mb-8">Your Skin <br/><span class="italic">Reimagined.</span></h1><button class="bg-accent text-bg px-10 py-4 text-xs uppercase tracking-widest">View Treatments</button></div>
  </section>

  <section id="about" class="py-24 px-6 max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
    <img src="https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=800" class="rounded-lg shadow-lg" />
    <div class="space-y-8"><span class="text-accent text-xs uppercase tracking-widest font-bold">Bespoke Clinical Care</span><h2 class="text-4xl md:text-6xl font-serif">Precision Meets Radiance.</h2><p class="text-primary/70 text-lg">We combine medical-grade technology with a boutique spa experience for visible, lasting results.</p></div>
  </section>

  <footer class="bg-[#1a1a1a] text-bg py-20 text-center uppercase text-[10px] tracking-widest opacity-40">© 2026 Lumière Skin Clinic — Powered by Launch.Skin</footer>

  <script is:inline>
    lucide.createIcons();
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('navbar');
      const btn = document.getElementById('nav-btn');
      if (window.scrollY > 50) { nav.classList.add('scrolled'); btn.classList.add('scrolled'); nav.classList.replace('text-bg', 'text-primary'); }
      else { nav.classList.remove('scrolled'); btn.classList.remove('scrolled'); nav.classList.replace('text-primary', 'text-bg'); }
    });
  </script>
</body>
</html>
